# Zephyr Scale API token.
ZEPHYR_API_TOKEN=replace-with-your-token

# Jira/Zephyr project key and parent folder scope.
ZEPHYR_PROJECT_KEY=QA
ZEPHYR_PARENT_FOLDER_ID=24734755
ZEPHYR_BASE_URL=https://api.zephyrscale.smartbear.com/v2
ZEPHYR_FETCH_TEST_STEPS=true
ARCHIVE_STATUS_NAMES=Archived,Deprecated
# Optional. Leave blank unless your Zephyr tenant exposes an audit endpoint.
ZEPHYR_AUDIT_ENDPOINT_TEMPLATE=

# PostgreSQL connection used by FastAPI and the poller.
POSTGRES_USER=zephyr_user
POSTGRES_PASSWORD=replace-with-a-local-db-password
POSTGRES_DB=zephyr_audit
DATABASE_URL=postgresql+asyncpg://zephyr_user:zephyr_password@localhost:5432/zephyr_audit

# Shared read API key for the dashboard/API. Use a strong secret outside local dev.
AUDIT_API_KEY=replace-with-a-long-random-value
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_MAX_LIMIT=1000
# IANA timezone for calendar-week sidebar metrics (Monday 00:00 boundary). Fallback: TZ env, then UTC.
STATS_TIMEZONE=

# Optional Jira user lookup for actor display names.
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=

# Optional Slack alert delivery.
SLACK_WEBHOOK_URL=
ALERT_BATCH_SIZE=50
ALERT_MAX_RETRIES=3
ALERT_INITIAL_DELAY_SECONDS=2

# Poller concurrency (tune based on API rate limits).
FOLDER_FETCH_CONCURRENCY=20
TEST_STEP_FETCH_CONCURRENCY=100

# API rate limiting (requests per minute per client).
RATE_LIMIT_PER_MINUTE=120

# Retry settings for external API calls.
API_RETRY_COUNT=3
API_RETRY_DELAY_SECONDS=1

# Frontend environment variables (for Vite).
# VITE_API_BASE_URL=http://localhost:8000/api
# VITE_WS_URL=ws://localhost:8000/ws
# VITE_AUDIT_API_KEY=your-api-key

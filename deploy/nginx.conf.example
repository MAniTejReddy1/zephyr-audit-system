server {
    listen 80;
    server_name scopeguard-qa.internal.example.com;

    root /var/www/zephyr-audit-ui;
    index index.html;

    # Replace with SSO/VPN controls where available. Basic auth is a simple
    # internal fallback and prevents unauthenticated browser access.
    auth_basic "ScopeGuard QA";
    auth_basic_user_file /etc/nginx/.htpasswd;

    location / {
        try_files $uri /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Prefer injecting the shared API key at the proxy instead of shipping
        # it in the static React bundle.
        proxy_set_header X-API-Key "replace-with-a-server-side-secret";
    }
}
